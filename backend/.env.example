# Backend Server Configuration
PORT=4000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Main Application Database (for users and instances metadata)
DB_HOST=localhost
DB_PORT=5433
DB_USER=whatchat_admin
DB_PASSWORD=your-secure-password
DB_NAME=whatchat_system

# Evolution API Default Settings
EVOLUTION_BASE_IMAGE=atendai/evolution-api:latest
EVOLUTION_POSTGRES_IMAGE=postgres:15-alpine
EVOLUTION_REDIS_IMAGE=redis:7-alpine

# Port Range for New Instances (each user needs 3 ports)
PORT_RANGE_START=9000
# User 1: API=9000, Postgres=9001, Redis=9002
# User 2: API=9003, Postgres=9004, Redis=9005
# etc.

# Docker Compose Files Location
COMPOSE_FILES_DIR=D:/projects/whatchat-new/backend/docker-instances

# Your Personal Instance (keep as reference)
PERSONAL_EVOLUTION_URL=http://localhost:8080
PERSONAL_EVOLUTION_API_KEY=B4SecureKey2024Evolution
